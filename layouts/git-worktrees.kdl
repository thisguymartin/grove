// Git Worktrees Layout
//
// This is a STATIC fallback template used when you have a single worktree
// or want a fixed starting point. For a DYNAMIC layout that automatically
// creates one tab per worktree, use:
//
//   ./zellij/launch-worktrees.sh
//
// Tab structure (dynamic layout, N worktrees):
//
//   [ main ] [ feature-auth ] [ fix-login ] [ Overview ]
//      |            |               |              |
//   lazygit      lazygit         lazygit       live status
//   + AI agent   + AI agent      + AI agent    dashboard
//   + workbench  + workbench     + workbench
//
// Tab-bar at top for navigation, status-bar at bottom.
//
// Keyboard shortcuts for tabs (Zellij defaults):
//   Alt + Left / Right  — cycle tabs
//   Alt + t             — open new tab
//   Ctrl + o, d         — detach session (keep running in background)

layout {
    // Tab bar at top, status bar at bottom
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // Tab: main worktree
    // Replace cwd paths with your actual repo root
    tab name="main" color="green" {
        // LEFT: LazyGit (30%) | RIGHT: Workbench (top) + AI Agent (bottom)
        pane split_direction="vertical" {
            pane command="lazygit" name="LazyGit" size="30%" {
                // cwd "~/projects/my-repo"
            }
            pane split_direction="horizontal" size="70%" {
                pane name="Workbench" size="70%" {
                    // cwd "~/projects/my-repo"
                }
                pane command="claude" name="AI Agent" size="30%" {
                    // cwd "~/projects/my-repo"
                    focus true
                }
            }
        }
    }

    // Tab: example feature worktree
    // Duplicate this block for each additional worktree
    tab name="feature-branch" color="blue" {
        pane split_direction="vertical" {
            pane command="lazygit" name="LazyGit" size="30%" {
                // cwd "~/projects/worktrees/my-repo/feature-branch"
            }
            pane split_direction="horizontal" size="70%" {
                pane name="Workbench" size="70%" {
                    // cwd "~/projects/worktrees/my-repo/feature-branch"
                }
                pane command="claude" name="AI Agent" size="30%" {
                    // cwd "~/projects/worktrees/my-repo/feature-branch"
                    focus true
                }
            }
        }
    }

    // Tab: Overview — live project dashboards
    tab name="Overview" color="cyan" {
        pane split_direction="vertical" size="70%" {
            pane command="sh" name="Worktree Status" size="40%" {
                args "-c" "while true; do clear; ./worktree-status.sh; sleep 15; done"
            }
            pane command="sh" name="AI Status" size="30%" {
                args "-c" "while true; do clear; ./ai-status.sh; sleep 30; done"
            }
            pane command="sh" name="PR Status" size="30%" {
                args "-c" "while true; do clear; ./pr-status.sh; sleep 60; done"
            }
        }
        pane command="sh" name="Resources" size="30%" {
            args "-c" "while true; do clear; ./resource-monitor.sh; sleep 5; done"
        }
    }
}
